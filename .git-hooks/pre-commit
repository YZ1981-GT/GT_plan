#!/usr/bin/env bash
# pre-commit hook
#
# 检查项：
# 1. gitleaks protect --staged 拦截暂存区密钥泄漏（dev-tooling-modernization spec / Task 2）
# 2. check_file_size.py 文件行数门禁（whitelist 只减不增 / HARD_CAPS 防回弹）
#    —— 与 CI file-size-guard job 同源，本地先拦防止回弹（紧急救急 git commit --no-verify）

set -e

# ── 1. gitleaks 暂存区扫描 ──
if ! command -v gitleaks > /dev/null 2>&1; then
    echo "[pre-commit] ⚠️ gitleaks 未安装，跳过（CI 兜底）"
else
    echo "[pre-commit] 执行 gitleaks 暂存区扫描..."
    if ! gitleaks protect --staged --config .gitleaks.toml --redact; then
        echo ""
        echo "[pre-commit] ❌ gitleaks 检测到暂存区存在疑似密钥泄漏"
        echo "          请移除敏感信息后重新提交"
        echo "          紧急救急：git commit --no-verify"
        exit 1
    fi
    echo "[pre-commit] ✅ gitleaks 扫描通过"
fi

# ── 2. 文件行数门禁 ──
PY=$(command -v python || command -v python3 || true)
if [ -z "$PY" ]; then
    echo "[pre-commit] ⚠️ python 未找到，跳过文件大小门禁（CI 兜底）"
    exit 0
fi

echo "[pre-commit] 执行文件行数门禁..."
if ! "$PY" backend/scripts/check/check_file_size.py; then
    echo ""
    echo "[pre-commit] ❌ 文件行数超限/膨胀（见上方明细）"
    echo "          请拆分文件或抽伴生模块（优先），确有必要再更新 whitelist 基线"
    echo "          紧急救急：git commit --no-verify"
    exit 1
fi
echo "[pre-commit] ✅ 文件行数门禁通过"
exit 0
