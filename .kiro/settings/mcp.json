{
  "mcpServers": {
    "codegraph": {
      "command": "npx",
      "args": [
        "-y",
        "@colbymchenry/codegraph",
        "serve",
        "--mcp",
        "--no-watch",
        "-p",
        "D:/GT_plan"
      ],
      "env": {},
      "disabled": false,
      "autoApprove": [
        "codegraph_search",
        "codegraph_context",
        "codegraph_trace",
        "codegraph_callers",
        "codegraph_callees",
        "codegraph_impact",
        "codegraph_node",
        "codegraph_explore",
        "codegraph_files",
        "codegraph_status"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {},
      "disabled": false,
      "autoApprove": [
        "browser_navigate",
        "browser_snapshot",
        "browser_click",
        "browser_type",
        "browser_press_key",
        "browser_take_screenshot",
        "browser_wait_for",
        "browser_console_messages",
        "browser_network_requests",
        "browser_evaluate",
        "browser_close",
        "browser_resize",
        "browser_tabs",
        "browser_handle_dialog",
        "browser_navigate_back",
        "browser_select_option",
        "browser_drag",
        "browser_hover",
        "browser_file_upload",
        "browser_fill_form"
      ]
    }
  }
}