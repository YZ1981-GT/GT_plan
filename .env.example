# ============================================================
# 审计作业平台 — Docker Compose 环境变量配置
# 复制此文件为 .env 并根据实际环境修改
# ============================================================

# ----------------------------------------------------------
# PostgreSQL 数据库配置
# ----------------------------------------------------------

# 数据库用户名（默认: postgres）
PG_USER=postgres

# 数据库密码（生产环境请使用强密码）
PG_PASSWORD=postgres

# 数据库名称（默认: audit_platform）
PG_DB=audit_platform

# 数据库对外映射端口（默认: 5432）
PG_PORT=5432

# ----------------------------------------------------------
# 后端 DATABASE_URL 配置（应用层使用，asyncpg 驱动）
# ----------------------------------------------------------
# 生产环境（PostgreSQL，6000 并发必需）：
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/audit_platform
#
# 开发环境（SQLite，可选，仅用于本机快速调试）：
#   DATABASE_URL=sqlite+aiosqlite:///./audit.db
#
# 注意：应用在启动时会根据 URL 前缀自动选择连接池策略：
#   - postgresql+asyncpg://...  → pool_size=20, max_overflow=80, pool_recycle=1800
#   - sqlite+aiosqlite://...    → 轻量配置（仅供开发）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/audit_platform

# 连接池覆盖（可选，留空使用代码默认值）
# DB_POOL_SIZE=20       # PostgreSQL 生产：≥20
# DB_MAX_OVERFLOW=80    # PostgreSQL 生产：≥80（+pool_size 合计 100 连接）

# PgBouncer（压测/生产开启，开发默认直连 PG）
# DB_USE_PGBOUNCER=False
# DB_PGBOUNCER_HOST=localhost
# DB_PGBOUNCER_PORT=6432

# LLM 结构化输出（llm-structured-output）
# LLM_STRUCTURED_OUTPUT_ENABLED=True
# LLM_GUIDED_DECODING_ENABLED=True
# LLM_STRUCTURED_MAX_RETRIES=2

# OpenTelemetry / 检索 / Schemathesis（endpoint-fuzz-and-tracing）
# OTEL_ENABLED=False
# OTEL_EXPORTER=console
# OTEL_OTLP_ENDPOINT=http://localhost:4317
# RETRIEVAL_BM25_FALLBACK_ENABLED=True
# SCHEMATHESIS_MAX_EXAMPLES=5

# xlsx 只读 calamine（xlsx-read-acceleration）
# XLSX_READ_USE_CALAMINE=True

# Docling PDF 增强（dev-tooling，默认关）
# DOCLING_ENABLED=False

# ----------------------------------------------------------
# Redis 配置
# ----------------------------------------------------------

# Redis 连接地址（Docker 内部服务名，默认: redis://redis:6379/0）
REDIS_URL=redis://redis:6379/0

# Redis 对外映射端口（默认: 6379）
REDIS_PORT=6379

# ----------------------------------------------------------
# JWT 认证配置
# ----------------------------------------------------------

# JWT 签名密钥（必填，请使用随机字符串，如: openssl rand -hex 32）
JWT_SECRET_KEY=change-me-to-a-random-secret

# JWT 签名算法（默认: HS256）
JWT_ALGORITHM=HS256

# Access Token 过期时间，单位：分钟（默认: 120，即2小时）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# Refresh Token 过期时间，单位：天（默认: 7）
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ----------------------------------------------------------
# 后端服务配置
# ----------------------------------------------------------

# FastAPI 后端对外映射端口（默认: 8000）
API_PORT=8000

# CORS 允许的前端源地址，多个用逗号分隔（默认含本地开发端口 5173/3030）
CORS_ORIGINS=http://localhost:5173,http://localhost:3030

# ----------------------------------------------------------
# ONLYOFFICE Document Server 配置
# ----------------------------------------------------------

# ONLYOFFICE 对外映射端口（默认: 8080）
OFFICE_PORT=8080

# ONLYOFFICE 服务地址
# - 后端跑在 Docker 内：http://onlyoffice:80
# - 后端跑在宿主机（start-dev.bat 9980）：http://localhost:8080
ONLYOFFICE_URL=http://localhost:8080

# OnlyOffice JWT 密钥（交付中心 callback 鉴权；留空则禁用在线编辑回调）
ONLYOFFICE_JWT_SECRET=

# OnlyOffice 回调基础 URL（如 http://localhost:9980/api/projects/{project_id}/deliverables/onlyoffice/callback）
ONLYOFFICE_CALLBACK_BASE=

# WOPI Host 基础地址（OnlyOffice 回调用，需能被容器访问宿主机后端）
# - 后端跑在宿主机：http://host.docker.internal:9980/wopi
# - 后端跑在 Docker 内：http://backend:8000/wopi
WOPI_BASE_URL=http://host.docker.internal:9980/wopi

# ----------------------------------------------------------
# 文件存储配置
# ----------------------------------------------------------

# 文件存储根目录（默认: ./storage）
STORAGE_ROOT=./storage

# ----------------------------------------------------------
# 附件存储配置
# ----------------------------------------------------------

# 附件主存储方式（paperless/local，默认: paperless）
ATTACHMENT_PRIMARY_STORAGE=paperless

# 是否启用本地存储回退（默认: true）
ATTACHMENT_FALLBACK_TO_LOCAL=true

# 本地存储根目录（默认: ./storage/attachments）
ATTACHMENT_LOCAL_STORAGE_ROOT=./storage/attachments

# Paperless-ngx 配置
PAPERLESS_URL=http://localhost:8010
PAPERLESS_TOKEN=
PAPERLESS_TIMEOUT=30

# ----------------------------------------------------------
# MinerU 配置
# ----------------------------------------------------------

# 是否启用 MinerU（默认: false，需要 GPU 支持）
MINERU_ENABLED=false

# MinerU API 地址（默认: http://localhost:8000）
MINERU_API_URL=http://localhost:8000

# 使用 CLI 模式（默认: true，直接调用本地 mineru 命令）
# 设置为 false 时使用 HTTP 模式（调用远程 MinerU API 服务）
MINERU_USE_CLI=true


# ----------------------------------------------------------
# vLLM 本地大模型配置（启动：docker compose --profile gpu up vllm）
# ----------------------------------------------------------

# vLLM 对外映射端口（默认: 8100，避免与后端 8000/9980 冲突）
VLLM_PORT=8100

# HuggingFace 缓存目录（模型下载到此目录）
VLLM_HF_CACHE=D:/vllm/hf-cache

# 模型名称（HuggingFace 模型 ID）
VLLM_MODEL=Kbenkhaled/Qwen3.5-27B-NVFP4

# 对外暴露的模型名称（API 调用时使用）
VLLM_MODEL_NAME=qwen3.5-27b

# 最大上下文长度（模型支持128K，按显存调整）
VLLM_MAX_MODEL_LEN=32768

# GPU 显存利用率（0.0-1.0）
VLLM_GPU_MEM=0.89

# NVFP4 GEMM 后端：marlin（解码快）或 flashinfer-cutlass（预填充快）
NVFP4_BACKEND=marlin

# HuggingFace Token（模型已离线缓存，通常不需要）
HF_TOKEN=

# ----------------------------------------------------------
# 云端归档存储配置（事务所内部服务器）
# ----------------------------------------------------------

# 存储类型：sftp / s3 / smb / local（默认: local 测试模式）
CLOUD_STORAGE_TYPE=local

# SFTP 配置（事务所内部文件服务器）
CLOUD_SFTP_HOST=192.168.1.100
CLOUD_SFTP_PORT=22
CLOUD_SFTP_USER=audit_archive
CLOUD_SFTP_PASSWORD=
CLOUD_SFTP_KEY_PATH=
CLOUD_SFTP_BASE_PATH=/archive/audit

# S3 兼容配置（MinIO / 阿里云 OSS / 内部对象存储）
CLOUD_S3_ENDPOINT=http://192.168.1.100:9000
CLOUD_S3_ACCESS_KEY=
CLOUD_S3_SECRET_KEY=
CLOUD_S3_BUCKET=audit-archive
CLOUD_S3_REGION=

# SMB 配置（Windows 共享文件夹）
CLOUD_SMB_SERVER=\\\\192.168.1.100\\archive
CLOUD_SMB_USER=
CLOUD_SMB_PASSWORD=

# 本地归档目录（测试用）
CLOUD_LOCAL_PATH=archive_cloud

# 上传时双写云端（默认开启，底稿上传时自动同步到云端服务器）
CLOUD_SYNC_ON_UPLOAD=true

# ----------------------------------------------------------
# 审计报告模板集成（audit-report-template-integration）
# ----------------------------------------------------------

# 灰度开关：False=ReportBodyService 旧路径；True=TemplateFillService 主路径
# USE_TEMPLATE_FILL_SERVICE=False

# 模板 manifest 根目录（留空=backend/data/audit_report_templates）
# TEMPLATE_MANIFEST_DIR=

# 报告正文 preview 会话 TTL（小时，默认 24）
# FILL_PREVIEW_TTL_HOURS=24
