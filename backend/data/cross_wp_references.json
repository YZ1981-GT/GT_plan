{
  "description": "跨底稿引用规则（=WP() 公式映射）",
  "version": "2025-R1",
  "usage_guide": {
    "说明": "本文件定义底稿间的数据引用关系，系统据此自动建立 =WP() 公式、stale 传播链路和依赖图。",
    "如何扩展": "在 references 数组中新增条目即可，系统热加载无需重启。每条规则需指定 source（数据来源底稿）和 targets（引用该数据的目标底稿）。",
    "字段说明": {
      "ref_id": "唯一标识，建议格式 CW-NNN",
      "description": "中文描述，说明这条引用的业务含义",
      "source_wp": "数据来源底稿编码（如 H1）",
      "source_sheet": "来源 sheet 名称（如 '折旧分配分析表H1-13'）",
      "source_cell": "来源单元格或区域（如 'C8' 或 '本期折旧合计'）",
      "targets": "引用该数据的目标底稿列表，每个含 wp_code/sheet/cell/formula",
      "category": "分类：depreciation(折旧)/salary(薪酬)/impairment(减值)/tax(税金)/profit(利润)/interest(利息)/cost(成本)/other",
      "severity": "引用断裂时的严重程度：blocking(阻断签字)/warning(警告)/info(提示)"
    },
    "扩展示例": "如需新增'研发费用资本化→无形资产'引用，添加: {ref_id:'CW-20', source_wp:'I6', source_sheet:'审定表', source_cell:'资本化金额', targets:[{wp_code:'I2', sheet:'审定表', cell:'本期增加'}], category:'other', severity:'warning'}"
  },
