    {
      "rule_id": "DV-001",
      "rule_type": "balance_check",
      "wp_code": "D0",
      "description": "收入循环函证审定数 = 未审数 + AJE + RJE",
      "formula": "audited == unaudited + aje + rje",
      "tolerance": 0.01,
      "severity": "blocking",
      "scope": "all_lines",
      "cells": {
        "audited": {
          "sheet": "审定表D0-1",
          "column": "审定数"
        },
        "unaudited": {
          "sheet": "审定表D0-1",
          "column": "未审数"
        },
        "aje": {
          "sheet": "审定表D0-1",
          "column": "AJE调整"
        },
        "rje": {
          "sheet": "审定表D0-1",
          "column": "RJE调整"
        }
      },
      "message_template": "借贷不平衡: 审定数({audited}) ≠ 未审数({unaudited}) + AJE({aje}) + RJE({rje}), 差异={diff}"
    },
