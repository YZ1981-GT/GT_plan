    {
      "rule_id": "VR-D4-01",
      "rule_type": "cross_reconciliation",
      "wp_code": "D4",
      "description": "营业收入合计 = 主营业务收入 + 其他业务收入",
      "formula": "ABS(revenue_total - (main_revenue + other_revenue)) < 1.0",
      "tolerance": 1.0,
      "severity": "blocking",
      "scope": "total",
      "sources": {
        "revenue_total": {"wp": "D4", "sheet": "营业收入审定表D4-1", "cell": "审定数"},
        "main_revenue": {"wp": "D4", "sheet": "营业收入审定表D4-1", "cell": "主营业务收入审定数"},
        "other_revenue": {"wp": "D4", "sheet": "营业收入审定表D4-1", "cell": "其他业务收入审定数"}
      },
      "message_template": "营业收入合计 ≠ 主营+其他，差异超过 1 元: 合计({revenue_total}) ≠ 主营({main_revenue}) + 其他({other_revenue}), 差异={diff}"
    },
    {
      "rule_id": "VR-D4-02",
      "rule_type": "cross_reconciliation",
      "wp_code": "D4",
      "description": "应收账款增长率 vs 营业收入增长率合理性",
      "formula": "ABS(ar_growth_rate - revenue_growth_rate) < 0.5",
      "tolerance": 0.5,
      "severity": "warning",
      "scope": "total",
      "sources": {
        "ar_growth_rate": {"wp": "D2", "sheet": "审定表D2-1", "cell": "变动率"},
        "revenue_growth_rate": {"wp": "D4", "sheet": "营业收入审定表D4-1", "cell": "变动率"}
      },
      "message_template": "应收账款增长率与收入增长率差异超过 50%，可能存在收入虚增风险: AR增长率({ar_growth_rate}) vs 收入增长率({revenue_growth_rate}), 差异={diff}"
    },
    {
      "rule_id": "VR-D4-03",
      "rule_type": "cross_reconciliation",
      "wp_code": "D4",
      "description": "毛利率波动 < 5%",
      "formula": "ABS(current_gross_margin - prior_gross_margin) < 0.05",
      "tolerance": 0.05,
      "severity": "warning",
      "scope": "total",
      "sources": {
        "current_gross_margin": {"wp": "D4", "sheet": "营业收入审定表D4-1", "cell": "本期毛利率"},
        "prior_gross_margin": {"wp": "D4", "sheet": "营业收入审定表D4-1", "cell": "上期毛利率"}
      },
      "message_template": "毛利率波动超过 5%，需关注成本配比异常: 本期({current_gross_margin}) vs 上期({prior_gross_margin}), 差异={diff}"
    },
    {
      "rule_id": "VR-D4-04",
      "rule_type": "cross_reconciliation",
      "wp_code": "D4",
      "description": "合同负债期末 vs D7-1 审定数一致",
      "formula": "ABS(d4_contract_liability - d7_audited) < 1.0",
      "tolerance": 1.0,
      "severity": "blocking",
