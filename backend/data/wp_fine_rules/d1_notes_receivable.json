          "closing_reclass": {"col": 13, "label": "期末重分类调整"},
          "closing_audited": {"col": 14, "label": "期末审定数"}
        }
      },
      "key_rows": {
        "individual": {"row": 12, "label": "按单项计提"},
        "portfolio": {"row": 17, "label": "按组合计提"},
