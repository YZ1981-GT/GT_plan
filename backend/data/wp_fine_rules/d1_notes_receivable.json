  "cross_references": [
    {"from": "D1-1.R18.C9", "to": "report://BS/BS-004#期末", "description": "审定表净值合计 = 资产负债表应收票据"},
    {"from": "D1-1.R10.C9", "to": "D1-2.R14.C11", "description": "审定表原值小计 = 明细表（按类别）合计"},
    {"from": "D1-1.R14.C9", "to": "D1-4.合计.C14", "description": "审定表坏账小计 = 坏账准备明细合计"},
    {"from": "D1-1.R18.C9", "to": "D1-1.R10.C9 - D1-1.R14.C9", "description": "净值 = 原值 - 坏账准备"},
    {"from": "D1-1.R19.C9", "to": "tb://1121#审定数", "description": "试算平衡表数 = 试算表应收票据审定数"},
    {"from": "D1-4.期初+变动", "to": "D1-4.期末", "description": "期初+计提+其他增加-转回-核销-其他减少 = 期末"},
    {"from": "D1-8.贴现合计", "to": "附注披露", "description": "贴现/背书未到期金额 → 附注表外披露"},
    {"from": "D1-3.关联方", "to": "D1-11.关联方检查", "description": "明细表关联方 → 关联方检查表"}
  ],
  "audit_checks": [
    {"code": "D1-CHK-01", "type": "balance", "severity": "blocking", "description": "审定表净值合计 = 试算表应收票据审定数"},
    {"code": "D1-CHK-02", "type": "balance", "severity": "blocking", "description": "审定表净值合计 = 报表应收票据行"},
    {"code": "D1-CHK-03", "type": "cross_ref", "severity": "warning", "description": "审定表原值小计 = 明细表（按类别）合计"},
    {"code": "D1-CHK-04", "type": "cross_ref", "severity": "warning", "description": "审定表坏账小计 = 坏账准备明细合计"},
    {"code": "D1-CHK-05", "type": "formula", "severity": "blocking", "description": "净值 = 原值 - 坏账准备（各行）"},
    {"code": "D1-CHK-06", "type": "movement", "severity": "warning", "description": "坏账准备：期初+计提+其他增加-转回-核销-其他减少 = 期末"},
    {"code": "D1-CHK-07", "type": "completeness", "severity": "warning", "description": "票据备查簿记录数 ≥ 明细表记录数"},
    {"code": "D1-CHK-08", "type": "check", "severity": "warning", "description": "贴现/背书未到期票据已在附注中披露"},
    {"code": "D1-CHK-09", "type": "check", "severity": "info", "description": "银行承兑汇票vs商业承兑汇票占比分析"},
    {"code": "D1-CHK-10", "type": "check", "severity": "warning", "description": "票据质押情况已检查并披露"}
  ]
}
