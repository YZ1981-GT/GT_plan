  "description": "E-N 实质性程序循环校验规则定义",
  "version": "2025-R1",
  "rules": [
    {
      "rule_id": "DV-101",
      "rule_type": "balance_check",
      "wp_code": "E1",
      "description": "货币资金审定数 = 未审数 + AJE + RJE",
      "formula": "audited == unaudited + aje + rje",
      "tolerance": 0.01,
      "severity": "blocking",
      "scope": "all_lines",
      "cells": {
        "audited": {"sheet": "审定表E1-1", "column": "审定数"},
        "unaudited": {"sheet": "审定表E1-1", "column": "未审数"},
        "aje": {"sheet": "审定表E1-1", "column": "AJE调整"},
        "rje": {"sheet": "审定表E1-1", "column": "RJE调整"}
      },
      "message_template": "借贷不平衡: 审定数({audited}) ≠ 未审数({unaudited}) + AJE({aje}) + RJE({rje}), 差异={diff}"
    },
    {
      "rule_id": "DV-102",
      "rule_type": "tb_consistency",
      "wp_code": "E1",
      "description": "货币资金审定数与试算平衡表一致",
      "formula": "audited == tb_amount",
      "tolerance": 0.01,
      "severity": "warning",
      "scope": "total_line",
      "cells": {
        "audited": {"sheet": "审定表E1-1", "column": "审定数"},
        "tb_amount": {"sheet": "TB", "column": "审定数"}
      },
      "message_template": "审定数({audited})与试算平衡表({tb_amount})不一致, 差异={diff}"
    },
