    {
      "rule_id": "DV-121",
      "wp_code": "E1",
      "rule_name": "余额调节差异",
      "rule_type": "balance_check",
      "formula": "abs(bank_statement_balance - (book_balance + outstanding_deposits - outstanding_checks)) == 0",
      "description": "银行余额调节表调节后差异必须为零",
      "severity": "blocking",
      "auto_check": true
    },
    {
      "rule_id": "DV-122",
      "wp_code": "E1",
      "rule_name": "受限资金披露",
      "rule_type": "completeness_check",
      "formula": "if restricted_cash > 0 then disclosure_exists == true",
      "description": "存在受限货币资金时必须在附注中披露",
      "severity": "warning",
      "auto_check": true
    },
    {
      "rule_id": "DV-123",
      "wp_code": "F2",
      "rule_name": "监盘差异率",
      "rule_type": "threshold_check",
      "formula": "abs(count_quantity - book_quantity) / book_quantity < materiality * 0.05",
      "description": "存货监盘差异不得超过重要性水平的5%",
      "severity": "warning",
      "auto_check": true
    },
    {
      "rule_id": "DV-124",
      "wp_code": "F2",
      "rule_name": "库龄跌价计提",
      "rule_type": "completeness_check",
      "formula": "if aging_days > 365 then provision_amount > 0",
      "description": "库龄超过1年的存货必须计提跌价准备",
      "severity": "warning",
      "auto_check": true
    },
    {
      "rule_id": "DV-125",
      "wp_code": "G1",
      "rule_name": "权益法一致性",
      "rule_type": "consistency_check",
      "formula": "if holding_ratio >= 0.2 then method == 'equity_method'",
      "description": "持股比例≥20%应采用权益法核算",
      "severity": "warning",
      "auto_check": true
    },
    {
      "rule_id": "DV-126",
      "wp_code": "G1",
      "rule_name": "投资收益核对",
      "rule_type": "recalculation_check",
      "formula": "abs(investment_income - investee_net_profit * holding_ratio) / abs(investee_net_profit * holding_ratio) < 0.01",
      "description": "投资收益应等于被投资方净利润乘以持股比例",
      "severity": "warning",
      "auto_check": true
    },
    {
      "rule_id": "DV-127",
      "wp_code": "H1",
      "rule_name": "折旧重算差异",
      "rule_type": "recalculation_check",
      "formula": "abs(recalc_depreciation - book_depreciation) / abs(book_depreciation) < 0.01",
      "description": "折旧重新计算差异不得超过1%",
      "severity": "warning",
      "auto_check": true
    },
    {
      "rule_id": "DV-128",
      "wp_code": "H1",
      "rule_name": "处置损益核对",
      "rule_type": "recalculation_check",
      "formula": "disposal_gain_loss == disposal_proceeds - book_value - disposal_tax",
      "description": "处置损益应等于处置收入减去账面价值减去相关税费",
      "severity": "blocking",
      "auto_check": true
    },
    {
      "rule_id": "DV-129",
      "wp_code": "I1",
      "rule_name": "摊销重算差异",
      "rule_type": "recalculation_check",
      "formula": "abs(recalc_amortization - book_amortization) / abs(book_amortization) < 0.01",
      "description": "无形资产摊销重新计算差异不得超过1%",
      "severity": "warning",
      "auto_check": true
    },
    {
      "rule_id": "DV-130",
      "wp_code": "J1",
      "rule_name": "五险一金完整性",
      "rule_type": "completeness_check",
      "formula": "pension + medical + unemployment + injury + maternity + housing_fund > 0",
      "description": "五险一金各项计提必须完整，不得遗漏",
      "severity": "warning",
      "auto_check": true
    },
    {
      "rule_id": "DV-131",
      "wp_code": "J1",
      "rule_name": "薪酬合同一致",
      "rule_type": "consistency_check",
      "formula": "actual_salary <= contract_salary",
      "description": "实际发放薪酬不得超过劳动合同约定金额",
      "severity": "warning",
      "auto_check": false
    },
    {
      "rule_id": "DV-132",
      "wp_code": "K8",
      "rule_name": "费用预算对比",
      "rule_type": "threshold_check",
      "formula": "actual_expense <= budget_amount * 1.2",
      "description": "管理费用实际发生额不得超过预算的120%",
      "severity": "warning",
      "auto_check": false
    },
    {
      "rule_id": "DV-133",
      "wp_code": "L1",
      "rule_name": "利息重算核对",
      "rule_type": "recalculation_check",
      "formula": "abs(recalc_interest - book_interest) / abs(book_interest) < 0.01 where recalc_interest = principal * rate * days / 365",
      "description": "利息费用重算应等于本金×利率×天数÷365，差异不超过1%",
      "severity": "warning",
      "auto_check": true
